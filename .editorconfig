root = true

###############################
# Core EditorConfig settings  #
###############################

[*]
charset = utf-8
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = crlf

# YAML, JSON, XML, and related config use 2-space indent.
[*.{yml,yaml,json,xml,csproj,props,targets,slnx}]
indent_size = 2

# Markdown keeps trailing whitespace significant for line breaks.
[*.md]
trim_trailing_whitespace = false

# PowerShell scripts
[*.{ps1,psm1,psd1}]
indent_size = 4

###############################
# .NET / C# style defaults
###############################

[*.cs]
# Indentation and wrapping
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = one_less_than_current

# Namespace and using organization
csharp_using_directive_placement = outside_namespace:suggestion
csharp_style_namespace_declarations = file_scoped:suggestion

# 'var' preferences
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion
csharp_style_expression_bodied_accessors = when_on_single_line:suggestion
csharp_style_expression_bodied_lambdas = when_on_single_line:suggestion
csharp_style_expression_bodied_local_functions = when_on_single_line:suggestion

# Null-handling and modern language features
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion
csharp_style_prefer_null_check_over_type_check = true:suggestion
csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion

# Modifier ordering
csharp_preferred_modifier_order = public, private, protected, internal, file, static, extern, new, virtual, abstract, sealed, override, readonly, unsafe, required, volatile, async:suggestion

# Brace style. Downgraded to suggestion so the existing single-line-if style
# in the codebase is not a build warning. Phase 6 will either standardize on
# always-braces and fix call-sites in bulk, or confirm the current style.
csharp_prefer_braces = true:suggestion

# New-line preferences
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

# Spacing
csharp_space_around_binary_operators = before_and_after

#########################################
# Analyzer severity tweaks for this repo
#########################################

# --- Stylistic rules: downgraded to suggestion ---

# IDE0011: Add braces. Matches csharp_prefer_braces above.
dotnet_diagnostic.IDE0011.severity = suggestion

# IDE0130: Namespace should match folder. Intentionally flat in
# Commands/Services/Infrastructure layouts.
dotnet_diagnostic.IDE0130.severity = suggestion

# --- Performance suggestions: downgraded, not silenced ---

# CA1848: Use LoggerMessage delegates. Revisit once hot-path profiling
# justifies the upgrade.
dotnet_diagnostic.CA1848.severity = suggestion

# CA1873: Avoid potentially expensive logging. Revisit with CA1848 cleanup.
dotnet_diagnostic.CA1873.severity = suggestion

# CA1869: Cache JsonSerializerOptions. Minor hot-path concern in a background
# service; scheduled for Phase 6 cleanup.
dotnet_diagnostic.CA1869.severity = suggestion

# CA1859: Use concrete types where possible for performance. Mostly
# test-harness variable typing; deliberate for abstraction elsewhere.
dotnet_diagnostic.CA1859.severity = suggestion

# CA1305: Specify IFormatProvider. Most call sites already use
# InvariantCulture; the remaining ones are scheduled for Phase 6 cleanup.
dotnet_diagnostic.CA1305.severity = suggestion

# --- Rules that do not apply to this project ---

# CA2007: ConfigureAwait(false). No synchronization context in a Worker /
# console host.
dotnet_diagnostic.CA2007.severity = none

# CA1031: Catch specific exceptions. Background-sync code intentionally
# catches broadly and logs to avoid crashing the service.
dotnet_diagnostic.CA1031.severity = suggestion

# --- Rules that stay as-is and are worth fixing (Phase 6) ---
#
# CA1001: Types with IDisposable fields must implement IDisposable.
# CA1068: CancellationToken parameters must come last.
# CA1716: Identifiers should not match language keywords.
# CA2254: Logging message templates should be constant.
# CA1822: Members that do not access instance data should be static.
#
# These remain at their default severity (warning) so that new occurrences
# are surfaced during development. The existing occurrences are tracked in
# Phase 6 of the release-readiness plan.

#########################################
# Test project overrides
#########################################

# xUnit convention uses Method_State_Result naming, which trips CA1707.
# Culture-sensitive parses and cached JsonSerializerOptions are also not
# meaningful in test assertions.
[{tests/**/*.cs,**/*Tests.cs}]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA1305.severity = none
dotnet_diagnostic.CA1869.severity = none
dotnet_diagnostic.CA1859.severity = none
dotnet_diagnostic.CA1822.severity = none
dotnet_diagnostic.CA1873.severity = none
dotnet_diagnostic.IDE0011.severity = none
